@using Oqtane.Modules.Controls
@using GIBS.Module.DateTimeCalc.Services
@using GIBS.Module.DateTimeCalc.Models
@using Oqtane.Modules.HtmlText.Services

@namespace GIBS.Module.DateTimeCalc
@inherits ModuleBase
@inject IDateTimeCalcService DateTimeCalcService
@inject IHtmlTextService HtmlTextService
@inject NavigationManager NavigationManager
@inject IStringLocalizer<Edit> Localizer

<form @ref="form" class="@(validated ? " was-validated" : "needs-validation")" novalidate>
    <div class="container">
        <div class="row mb-1 align-items-center">
            <Label Class="col-sm-3" For="name" HelpText="Enter a name" ResourceKey="Name">Name: </Label>
            <div class="col-sm-9">
                <input id="name" class="form-control" @bind="@_name" required />
            </div>
        </div>
        <div class="row mb-1 align-items-center">
            <Label Class="col-sm-3" For="startDate" HelpText="Enter a start date" ResourceKey="StartDate">Start Date: </Label>
            <div class="col-sm-9">
                <input id="startDate" type="datetime-local" class="form-control" @bind="@_startDate" />
            </div>
        </div>
        <div class="row mb-1 align-items-center">
            <Label Class="col-sm-3" For="endDate" HelpText="Enter an end date" ResourceKey="EndDate">End Date: </Label>
            <div class="col-sm-9">
                <input id="endDate" type="datetime-local" class="form-control" @bind="@_endDate" />
            </div>
        </div>
        <div class="row mb-1 align-items-center">
            <Label Class="col-sm-3 align-items-start" For="template" HelpText="Enter the template" ResourceKey="Template">Template: </Label>
            <div class="col-sm-9">
                <RichTextEditor id="template" Content="@_template" @bind="@_template" @ref="@RichTextEditorHtml"></RichTextEditor>

            </div>
        </div>
        <div class="row mb-1 align-items-center">
            <Label Class="col-sm-3" ResourceKey="Show">Show Parts: </Label>
            <div class="col-sm-9">
                <div class="form-check form-check-inline">
                    <input id="showYears" type="checkbox" class="form-check-input" @bind="@_showYears" />
                    <Label Class="form-check-label" For="showYears" ResourceKey="ShowYears">Years</Label>
                </div>
                <div class="form-check form-check-inline">
                    <input id="showMonths" type="checkbox" class="form-check-input" @bind="@_showMonths" />
                    <Label Class="form-check-label" For="showMonths" ResourceKey="ShowMonths">Months</Label>
                </div>
                <div class="form-check form-check-inline">
                    <input id="showWeeks" type="checkbox" class="form-check-input" @bind="@_showWeeks" />
                    <Label Class="form-check-label" For="showWeeks" ResourceKey="ShowWeeks">Weeks</Label>
                </div>
                <div class="form-check form-check-inline">
                    <input id="showDays" type="checkbox" class="form-check-input" @bind="@_showDays" />
                    <Label Class="form-check-label" For="showDays" ResourceKey="ShowDays">Days</Label>
                </div>
                <div class="form-check form-check-inline">
                    <input id="showHours" type="checkbox" class="form-check-input" @bind="@_showHours" />
                    <Label Class="form-check-label" For="showHours" ResourceKey="ShowHours">Hours</Label>
                </div>
                <div class="form-check form-check-inline">
                    <input id="showMinutes" type="checkbox" class="form-check-input" @bind="@_showMinutes" />
                    <Label Class="form-check-label" For="showMinutes" ResourceKey="ShowMinutes">Minutes</Label>
                </div>
                <div class="form-check form-check-inline">
                    <input id="showSeconds" type="checkbox" class="form-check-input" @bind="@_showSeconds" />
                    <Label Class="form-check-label" For="showSeconds" ResourceKey="ShowSeconds">Seconds</Label>
                </div>
            </div>
        </div>
    </div>

    <br />
    @if (PageState.Action == "Edit")
    {
        <AuditInfo CreatedBy="@_createdby" CreatedOn="@_createdon" ModifiedBy="@_modifiedby" ModifiedOn="@_modifiedon"></AuditInfo>
    }
    
    <button type="button" class="btn btn-success" @onclick="Save">@Localizer["Save"]</button>
    <button type="button" class="btn btn-primary" @onclick="ClearForm">@Localizer["New"]</button>
    <NavLink class="btn btn-secondary" href="@NavigateUrl()">@Localizer["Cancel"]</NavLink>
    <br />
    <br />
</form>


@if (_dateTimeCalcs == null)
{
    <p><em>Loading...</em></p>
}
else
{

    <br />
    <br />
    @if (@_dateTimeCalcs.Count != 0)
    {
        <Pager Items="@_dateTimeCalcs">
            <Header>
            <th style="width: 1px;">&nbsp;</th>
            <th style="width: 1px;">&nbsp;</th>
            <th>@Localizer["Name"]</th>
            <th>@Localizer["StartDate"]</th>
            <th>@Localizer["EndDate"]</th>
            <th>@Localizer["Years"]</th>
            <th>@Localizer["Months"]</th>
            <th>@Localizer["Weeks"]</th>
            <th>@Localizer["Days"]</th>
            <th>@Localizer["Hours"]</th>
            <th>@Localizer["Minutes"]</th>
            <th>@Localizer["Seconds"]</th>
            </Header>
            <Row>
                <td><ActionLink Action="Edit" Parameters="@($"id=" + context.DateTimeCalcId.ToString())" ResourceKey="Edit" /></td>
                <td><ActionDialog Header="Delete DateTimeCalc" Message="Are You Sure You Wish To Delete This DateTimeCalc?" Action="Delete" Security="SecurityAccessLevel.Edit" Class="btn btn-danger" OnClick="@(async () => await Delete(context))" ResourceKey="Delete" Id="@context.DateTimeCalcId.ToString()" /></td>
                <td>@context.Name</td>
                <td>@context.StartDate?.ToString("g")</td>
                <td>@context.EndDate?.ToString("g")</td>
                <td><input type="checkbox" checked="@context.ShowYears" disabled /></td>
                <td><input type="checkbox" checked="@context.ShowMonths" disabled /></td>
                <td><input type="checkbox" checked="@context.ShowWeeks" disabled /></td>
                <td><input type="checkbox" checked="@context.ShowDays" disabled /></td>
                <td><input type="checkbox" checked="@context.ShowHours" disabled /></td>
                <td><input type="checkbox" checked="@context.ShowMinutes" disabled /></td>
                <td><input type="checkbox" checked="@context.ShowSeconds" disabled /></td>
            </Row>
        </Pager>
    }
    else
    {
        <p>@Localizer["Message.DisplayNone"]</p>
    }
    <div>
        <ActionLink Action="Add" Security="SecurityAccessLevel.Edit" Text="Add DateTimeCalc" ResourceKey="AddNew" />
    </div>
}

@code {



    public override SecurityAccessLevel SecurityAccessLevel => SecurityAccessLevel.Edit;

    public override string Actions => "Add,Edit";

    public override string Title => "Manage DateTimeCalc";

    public override List<Resource> Resources => new List<Resource>()
    {
        new Resource { ResourceType = ResourceType.Stylesheet, Url = ModulePath() + "Module.css" }
    };

    private ElementReference form;
    private bool validated = false;

    private int _id;
    private string _name;
    private DateTime? _startDate;
    private DateTime? _endDate;
    private bool _showYears;
    private bool _showMonths;
    private bool _showWeeks;
    private bool _showDays;
    private bool _showHours;
    private bool _showMinutes;
    private bool _showSeconds;
    private string _template;
    private string _createdby;
    private DateTime _createdon;
    private string _modifiedby;
    private DateTime _modifiedon;
    private RichTextEditor RichTextEditorHtml;

    private List<DateTimeCalc> _dateTimeCalcs;
    private int _prevId = -1;
    private int _nextId = -1;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            await LoadData();
            if (PageState.Action == "Edit")
            {
                _id = Int32.Parse(PageState.QueryString["id"]);
                var dateTimeCalc = _dateTimeCalcs.FirstOrDefault(item => item.DateTimeCalcId == _id);
                if (dateTimeCalc != null)
                {
                    _name = dateTimeCalc.Name;
                    _startDate = dateTimeCalc.StartDate;
                    _endDate = dateTimeCalc.EndDate;
                    _showYears = dateTimeCalc.ShowYears;
                    _showMonths = dateTimeCalc.ShowMonths;
                    _showWeeks = dateTimeCalc.ShowWeeks;
                    _showDays = dateTimeCalc.ShowDays;
                    _showHours = dateTimeCalc.ShowHours;
                    _showMinutes = dateTimeCalc.ShowMinutes;
                    _showSeconds = dateTimeCalc.ShowSeconds;
                    _template = dateTimeCalc.Template;
                    _createdby = dateTimeCalc.CreatedBy;
                    _createdon = dateTimeCalc.CreatedOn;
                    _modifiedby = dateTimeCalc.ModifiedBy;
                    _modifiedon = dateTimeCalc.ModifiedOn;

              //      SetNavigation();
                }
            }
            else
            {
                ClearForm();
            }
        }
        catch (Exception ex)
        {
            await logger.LogError(ex, "Error Loading DateTimeCalc {DateTimeCalcId} {Error}", _id, ex.Message);
            AddModuleMessage(Localizer["Message.LoadError"], MessageType.Error);
        }
    }

    private async Task LoadData()
    {
        _dateTimeCalcs = await DateTimeCalcService.GetDateTimeCalcsAsync(ModuleState.ModuleId);
    }

    private void ClearForm()
    {
        validated = false;
        _id = 0;
        _name = string.Empty;
        _startDate = null;
        _endDate = null;
        _showYears = true;
        _showMonths = true;
        _showWeeks = true;
        _showDays = true;
        _showHours = true;
        _showMinutes = true;
        _showSeconds = true;
        _template = string.Empty;
        _createdby = string.Empty;
        _createdon = default;
        _modifiedby = string.Empty;
        _modifiedon = default;
        _prevId = -1;
        _nextId = -1;
        PageState.Action = "Add";
    }

    // private void SetNavigation()
    // {
    //     _prevId = -1;
    //     _nextId = -1;
    //     if (_dateTimeCalcs != null && _dateTimeCalcs.Any())
    //     {
    //         var currentIndex = _dateTimeCalcs.FindIndex(item => item.DateTimeCalcId == _id);
    //         if (currentIndex > 0)
    //         {
    //             _prevId = _dateTimeCalcs[currentIndex - 1].DateTimeCalcId;
    //         }
    //         if (currentIndex != -1 && currentIndex < _dateTimeCalcs.Count - 1)
    //         {
    //             _nextId = _dateTimeCalcs[currentIndex + 1].DateTimeCalcId;
    //         }
    //     }
    // }

    private void NavigateToRecord(int id)
    {
        if (id != -1)
        {
            NavigationManager.NavigateTo(NavigateUrl("Edit", "id=" + id));
        }
    }

    private async Task Save()
    {
        try
        {
            validated = true;
            var interop = new Oqtane.UI.Interop(JSRuntime);
            if (await interop.FormValid(form))
            {
                _template = await RichTextEditorHtml.GetHtml();

                if (PageState.Action == "Add")
                {
                    DateTimeCalc DateTimeCalc = new DateTimeCalc();
                    DateTimeCalc.ModuleId = ModuleState.ModuleId;
                    DateTimeCalc.Name = _name;
                    DateTimeCalc.StartDate = _startDate;
                    DateTimeCalc.EndDate = _endDate;
                    DateTimeCalc.ShowYears = _showYears;
                    DateTimeCalc.ShowMonths = _showMonths;
                    DateTimeCalc.ShowWeeks = _showWeeks;
                    DateTimeCalc.ShowDays = _showDays;
                    DateTimeCalc.ShowHours = _showHours;
                    DateTimeCalc.ShowMinutes = _showMinutes;
                    DateTimeCalc.ShowSeconds = _showSeconds;
                    DateTimeCalc.Template = _template;
                    DateTimeCalc = await DateTimeCalcService.AddDateTimeCalcAsync(DateTimeCalc);
                    await logger.LogInformation("DateTimeCalc Added {DateTimeCalc}", DateTimeCalc);
                }
                else
                {
                    DateTimeCalc DateTimeCalc = await DateTimeCalcService.GetDateTimeCalcAsync(_id, ModuleState.ModuleId);
                    DateTimeCalc.Name = _name;
                    DateTimeCalc.StartDate = _startDate;
                    DateTimeCalc.EndDate = _endDate;
                    DateTimeCalc.ShowYears = _showYears;
                    DateTimeCalc.ShowMonths = _showMonths;
                    DateTimeCalc.ShowWeeks = _showWeeks;
                    DateTimeCalc.ShowDays = _showDays;
                    DateTimeCalc.ShowHours = _showHours;
                    DateTimeCalc.ShowMinutes = _showMinutes;
                    DateTimeCalc.ShowSeconds = _showSeconds;
                    DateTimeCalc.Template = _template;
                    await DateTimeCalcService.UpdateDateTimeCalcAsync(DateTimeCalc);
                    await logger.LogInformation("DateTimeCalc Updated {DateTimeCalc}", DateTimeCalc);
                }



                //NavigateUrl();
                //PageState.Action = "Add";
                ClearForm();
                StateHasChanged();
                await LoadData();
                
                
            }
            else
            {
                AddModuleMessage(Localizer["Message.SaveValidation"], MessageType.Warning);
            }
        }
        catch (Exception ex)
        {
            await logger.LogError(ex, "Error Saving DateTimeCalc {Error}", ex.Message);
            AddModuleMessage(Localizer["Message.SaveError"], MessageType.Error);
        }
    }

    private async Task Delete(DateTimeCalc DateTimeCalc)
    {
        try
        {
            await DateTimeCalcService.DeleteDateTimeCalcAsync(DateTimeCalc.DateTimeCalcId, ModuleState.ModuleId);
            await logger.LogInformation("DateTimeCalc Deleted {DateTimeCalc}", DateTimeCalc);
            await LoadData();
            StateHasChanged();
        }
        catch (Exception ex)
        {
            await logger.LogError(ex, "Error Deleting DateTimeCalc {DateTimeCalc} {Error}", DateTimeCalc, ex.Message);
            AddModuleMessage(Localizer["Message.DeleteError"], MessageType.Error);
        }
    }
}